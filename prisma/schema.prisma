generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ROLES ───────────────────────────────────────────────
enum TipoRol {
  SUPER_ADMIN
  INSTRUCTOR
  DESIGNADOR
  VERIFICADOR
  ARBITRO
  MESA
  ESTADISTICO
  AFICIONADO
}

enum EstadoVerificacion {
  PENDIENTE
  VERIFICADO
  RECHAZADO
  SUSPENDIDO
}

// ─── USUARIOS ────────────────────────────────────────────
model Usuario {
  id                 String             @id @default(uuid())
  email              String             @unique
  nombre             String
  apellido           String
  cedula             String?            @unique
  fechaNacimiento    DateTime?
  telefono           String?
  ciudad             String?
  barrio             String?
  genero             String             @default("Masculino")
  fotoCedulaUrl      String?
  fotoCarnetUrl      String?
  avatarUrl          String?
  clubFavorito       String?
  alertasCategorias  String?
  estadoVerificacion EstadoVerificacion @default(PENDIENTE)
  verificadoPor      String?
  verificadoEn       DateTime?
  motivoRechazo      String?
  qrToken            String?            @unique
  aceptoTerminosEn   DateTime?
  activo             Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  roles                UsuarioRol[]
  inscripciones        Inscripcion[]
  progresoModulos      ProgresoModulo[]
  respuestasExamen     RespuestaExamen[]
  certificados         Certificado[]
  designaciones        Designacion[]
  honorarios           Honorario[]
  honorariosPropios    HonorarioPropio[]
  notificaciones       Notificacion[]
  notifEnviadas        Notificacion[]     @relation("NotifEnviadas")
  cursosComoInstructor Curso[]            @relation("InstructorCurso")

  @@map("usuarios")
}

model UsuarioRol {
  id        String   @id @default(uuid())
  usuarioId String
  rol       TipoRol
  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, rol])
  @@map("usuario_roles")
}

// ─── CURSOS ──────────────────────────────────────────────
enum DisciplinaCurso {
  ARBITROS
  MESA
  ESTADISTICOS
}

enum NivelCurso {
  A_INICIAL
  B_ACTUALIZACION
  C_AVANZADO
}

enum EstadoCurso {
  BORRADOR
  ACTIVO
  INACTIVO
}

model Curso {
  id            String          @id @default(uuid())
  nombre        String
  descripcion   String          @db.Text
  disciplina    DisciplinaCurso
  nivel         NivelCurso
  precio        Decimal         @default(0) @db.Decimal(10, 2)
  esGratuito    Boolean         @default(false)
  estado        EstadoCurso     @default(BORRADOR)
  imagen        String?
  duracionTotal Int?
  instructorId  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  instructor    Usuario?      @relation("InstructorCurso", fields: [instructorId], references: [id])
  modulos       Modulo[]
  inscripciones Inscripcion[]
  certificados  Certificado[]

  @@map("cursos")
}

model Modulo {
  id          String   @id @default(uuid())
  cursoId     String
  titulo      String
  descripcion String?  @db.Text
  contenido   String?  @db.Text
  videoUrl    String?
  archivoUrl  String?
  orden       Int
  duracion    Int?
  createdAt   DateTime @default(now())

  curso     Curso            @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  examen    Examen?
  progresos ProgresoModulo[]
  secciones ModuloSeccion[]

  @@map("modulos")
}

enum TipoSeccion {
  CONTENIDO
  TRUCO_MEMORIA
  CASO_PRACTICO
  TABLA_RESUMEN
  MINI_QUIZ
  TARJETAS_EXPANDIBLES
}

model ModuloSeccion {
  id        String       @id @default(uuid())
  moduloId  String
  titulo    String
  contenido String       @db.Text
  tipo      TipoSeccion  @default(CONTENIDO)
  orden     Int
  metadata  String?      @db.Text  // JSON para datos extra (quiz options, cards, etc)
  createdAt DateTime     @default(now())

  modulo Modulo @relation(fields: [moduloId], references: [id], onDelete: Cascade)

  @@map("modulo_secciones")
}

model Examen {
  id            String   @id @default(uuid())
  moduloId      String   @unique
  titulo        String
  instrucciones String?  @db.Text
  notaMinima    Int      @default(70)
  createdAt     DateTime @default(now())

  modulo     Modulo            @relation(fields: [moduloId], references: [id], onDelete: Cascade)
  preguntas  Pregunta[]
  respuestas RespuestaExamen[]

  @@map("examenes")
}

enum TipoPregunta {
  OPCION_MULTIPLE
  TEXTO_ABIERTO
}

model Pregunta {
  id       String       @id @default(uuid())
  examenId String
  texto    String       @db.Text
  tipo     TipoPregunta
  orden    Int
  puntaje  Int          @default(1)

  examen     Examen            @relation(fields: [examenId], references: [id], onDelete: Cascade)
  opciones   Opcion[]
  respuestas RespuestaExamen[]

  @@map("preguntas")
}

model Opcion {
  id         String  @id @default(uuid())
  preguntaId String
  texto      String
  esCorrecta Boolean @default(false)
  orden      Int

  pregunta Pregunta @relation(fields: [preguntaId], references: [id], onDelete: Cascade)

  @@map("opciones")
}

// ─── INSCRIPCIONES Y PROGRESO ────────────────────────────
enum EstadoInscripcion {
  PENDIENTE_PAGO
  ACTIVO
  COMPLETADO
  CANCELADO
}

model Inscripcion {
  id        String            @id @default(uuid())
  usuarioId String
  cursoId   String
  estado    EstadoInscripcion @default(PENDIENTE_PAGO)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  curso   Curso   @relation(fields: [cursoId], references: [id])
  pagos   Pago[]

  @@unique([usuarioId, cursoId])
  @@map("inscripciones")
}

// ─── PAGOS MANUALES ──────────────────────────────────────
enum EstadoPago {
  PENDIENTE_REVISION
  CONFIRMADO
  RECHAZADO
}

model Pago {
  id             String     @id @default(uuid())
  inscripcionId  String
  monto          Decimal    @db.Decimal(10, 2)
  comprobanteUrl String
  referencia     String?
  notas          String?
  estado         EstadoPago @default(PENDIENTE_REVISION)
  revisadoPor    String?
  revisadoEn     DateTime?
  motivoRechazo  String?
  notasAdmin     String?
  createdAt      DateTime   @default(now())

  inscripcion Inscripcion @relation(fields: [inscripcionId], references: [id])

  @@map("pagos")
}

model ProgresoModulo {
  id           String    @id @default(uuid())
  usuarioId    String
  moduloId     String
  completado   Boolean   @default(false)
  iniciadoEn   DateTime  @default(now())
  completadoEn DateTime?

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  modulo  Modulo  @relation(fields: [moduloId], references: [id])

  @@unique([usuarioId, moduloId])
  @@map("progreso_modulos")
}

model RespuestaExamen {
  id              String   @id @default(uuid())
  usuarioId       String
  examenId        String
  preguntaId      String
  opcionId        String?
  respuestaTexto  String?  @db.Text
  esCorrecta      Boolean?
  puntajeObtenido Int?
  createdAt       DateTime @default(now())

  usuario  Usuario  @relation(fields: [usuarioId], references: [id])
  examen   Examen   @relation(fields: [examenId], references: [id])
  pregunta Pregunta @relation(fields: [preguntaId], references: [id])

  @@map("respuestas_examenes")
}

// ─── CERTIFICADOS ────────────────────────────────────────
model Certificado {
  id        String   @id @default(uuid())
  usuarioId String
  cursoId   String
  pdfUrl    String?
  qrToken   String   @unique @default(uuid())
  notaFinal Int?
  emitidoEn DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  curso   Curso   @relation(fields: [cursoId], references: [id])

  @@unique([usuarioId, cursoId])
  @@map("certificados")
}

// ─── RECURSOS GRATUITOS ──────────────────────────────────
enum TipoRecurso {
  PDF
  VIDEO
  LINK
  IMAGEN
}

enum CategoriaRecurso {
  REGLAMENTO
  MANUAL
  VIDEO_INSTRUCTIVO
  FORMULARIO
  OTRO
}

model Recurso {
  id          String            @id @default(uuid())
  titulo      String
  descripcion String?           @db.Text
  tipo        TipoRecurso
  categoria   CategoriaRecurso  @default(OTRO)
  url         String
  esPublico   Boolean           @default(true)
  disciplina  DisciplinaCurso?
  activo      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  creadoPor   String?

  @@map("recursos")
}

// ─── NOTIFICACIONES ──────────────────────────────────────
enum TipoNotificacion {
  CARNET_VERIFICADO
  CARNET_RECHAZADO
  PAGO_CONFIRMADO
  PAGO_RECHAZADO
  CURSO_HABILITADO
  EXAMEN_DISPONIBLE
  MODULO_COMPLETADO
  CERTIFICADO_EMITIDO
  DESIGNACION_ASIGNADA
  DESIGNACION_CANCELADA
  PARTIDO_MODIFICADO
  HONORARIO_PAGADO
  MENSAJE_ADMIN
  SISTEMA
}

model Notificacion {
  id         String           @id @default(uuid())
  usuarioId  String
  tipo       TipoNotificacion
  titulo     String
  mensaje    String           @db.Text
  link       String?
  leido      Boolean          @default(false)
  leidoEn    DateTime?
  enviadoPor String?
  createdAt  DateTime         @default(now())

  usuario  Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  enviador Usuario? @relation("NotifEnviadas", fields: [enviadoPor], references: [id])

  @@map("notificaciones")
}

// ─── PARTIDOS Y DESIGNACIONES (FASE 2) ───────────────────
enum CategoriaPartido {
  PRIMERA_DIVISION
  SEGUNDA_DIVISION
  FEMENINO
  U21
  U18
  U16
  U14
  ESPECIAL
}

enum EstadoPartido {
  PROGRAMADO
  EN_CURSO
  FINALIZADO
  SUSPENDIDO
  CANCELADO
}

model Partido {
  id          String           @id @default(uuid())
  fecha       DateTime
  hora        String
  cancha      String
  ciudad      String
  categoria   CategoriaPartido
  equipoLocal String
  equipoVisit String
  descripcion String?
  estado      EstadoPartido    @default(PROGRAMADO)
  createdAt   DateTime         @default(now())
  creadoPor   String?

  designaciones Designacion[]
  honorarios    Honorario[]

  @@map("partidos")
}

enum RolDesignacion {
  ARBITRO_PRINCIPAL
  ARBITRO_ASISTENTE_1
  ARBITRO_ASISTENTE_2
  MESA_ANOTADOR
  MESA_CRONOMETRADOR
  MESA_OPERADOR_24S
  MESA_ASISTENTE
  ESTADISTICO
}

enum EstadoDesignacion {
  PENDIENTE
  CONFIRMADA
  RECHAZADA
  REEMPLAZADA
}

model Designacion {
  id          String            @id @default(uuid())
  partidoId   String
  usuarioId   String
  rol         RolDesignacion
  estado      EstadoDesignacion @default(PENDIENTE)
  notas       String?
  createdAt   DateTime          @default(now())
  asignadoPor String?

  partido   Partido    @relation(fields: [partidoId], references: [id])
  usuario   Usuario    @relation(fields: [usuarioId], references: [id])
  honorario Honorario?

  @@map("designaciones")
}

// ─── ARANCELES Y HONORARIOS (FASE 3) ─────────────────────
model Arancel {
  id          String           @id @default(uuid())
  categoria   CategoriaPartido
  rol         RolDesignacion
  monto       Decimal          @db.Decimal(10, 2)
  descripcion String?
  activo      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([categoria, rol])
  @@map("aranceles")
}

enum EstadoHonorario {
  PENDIENTE
  PAGADO
}

model Honorario {
  id            String          @id @default(uuid())
  designacionId String          @unique
  partidoId     String
  usuarioId     String
  monto         Decimal         @db.Decimal(10, 2)
  estado        EstadoHonorario @default(PENDIENTE)
  pagadoEn      DateTime?
  comprobante   String?
  notas         String?
  createdAt     DateTime        @default(now())

  designacion Designacion @relation(fields: [designacionId], references: [id])
  partido     Partido     @relation(fields: [partidoId], references: [id])
  usuario     Usuario     @relation(fields: [usuarioId], references: [id])

  @@map("honorarios")
}

// ─── CUERPO TÉCNICO ──────────────────────────────────────

enum RolCuerpoTecnico {
  ENTRENADOR_NACIONAL
  ENTRENADOR_EXTRANJERO
  ASISTENTE
  PREPARADOR_FISICO
  FISIO
  UTILERO
  NUTRICIONISTA
}

enum EstadoHabilitacion {
  PENDIENTE
  HABILITADO
  RECHAZADO
  SUSPENDIDO
}

model CuerpoTecnico {
  id                  String             @id @default(uuid())
  email               String             @unique
  nombre              String
  apellido            String
  cedula              String             @unique
  fechaNacimiento     DateTime
  telefono            String
  ciudad              String
  genero              String             @default("Masculino")
  nacionalidad        String             @default("Paraguaya")
  rol                 RolCuerpoTecnico
  fotoCarnetUrl       String?
  fotoCedulaUrl       String?
  tituloEntrenadorUrl String?
  tieneTitulo         Boolean            @default(false)
  razonSocial         String?
  ruc                 String?
  estadoHabilitacion  EstadoHabilitacion @default(PENDIENTE)
  pagoVerificado      Boolean            @default(false)
  pagoAutoVerificado  Boolean            @default(false)
  comprobanteUrl       String?
  documentosRequeridos String?           // JSON array: ["comprobante","foto_carnet","foto_cedula"]
  mensajeDocumentos    String?
  montoHabilitacion   Decimal            @default(0) @db.Decimal(10, 2)
  verificadoPor       String?
  verificadoEn        DateTime?
  motivoRechazo       String?
  qrToken             String?            @unique
  aceptoTerminosEn    DateTime?
  activo              Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  notificaciones NotificacionCT[]

  @@map("cuerpo_tecnico")
}

model NotificacionCT {
  id         String           @id @default(uuid())
  ctId       String
  tipo       TipoNotificacion
  titulo     String
  mensaje    String           @db.Text
  link       String?
  leido      Boolean          @default(false)
  leidoEn    DateTime?
  enviadoPor String?
  createdAt  DateTime         @default(now())

  ct CuerpoTecnico @relation(fields: [ctId], references: [id], onDelete: Cascade)

  @@map("notificaciones_ct")
}

model CtPreverificado {
  id                 String   @id @default(uuid())
  nombre             String
  nombreNormalizado   String   @map("nombre_normalizado")
  rol                String
  datosFactura       String?  @map("datos_factura")
  usado              Boolean  @default(false)
  usuarioCtId        String?  @map("usuarioCtId")
  createdAt          DateTime @default(now())

  @@map("ct_preverificados")
}

// ─── SITIO WEB PÚBLICO ──────────────────────────────────

enum CategoriaNoticia {
  GENERAL
  TORNEOS
  SELECCIONES
  ARBITRAJE
  INSTITUCIONAL
  CLUBES
}

model Noticia {
  id          String            @id @default(uuid())
  titulo      String
  slug        String            @unique
  extracto    String            @db.Text
  contenido   String            @db.Text
  imagenUrl   String?
  galeria     String?           @db.Text
  videoUrl    String?
  categoria   CategoriaNoticia
  destacada   Boolean           @default(false)
  publicada   Boolean           @default(false)
  publicadaEn DateTime?
  autorNombre String?
  creadoPor   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("noticias")
}

model HeroImage {
  id             String   @id @default(uuid())
  imageUrl       String   @db.Text
  focalDesktopX  Float    @default(50)
  focalDesktopY  Float    @default(50)
  focalMobileX   Float    @default(50)
  focalMobileY   Float    @default(50)
  orden          Int      @default(0)
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("hero_images")
}

model Club {
  id          String   @id @default(uuid())
  nombre      String
  slug        String   @unique
  sigla       String?
  logoUrl     String?
  ciudad      String
  direccion   String?
  telefono    String?
  email       String?
  sitioWeb    String?
  instagram   String?
  facebook    String?
  descripcion String?  @db.Text
  activo      Boolean  @default(true)
  orden       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("clubes")
}

model Seleccion {
  id          String   @id @default(uuid())
  nombre      String
  slug        String   @unique
  categoria   String
  genero      String
  imagenUrl   String?
  descripcion String?  @db.Text
  entrenador  String?
  logros      String?  @db.Text
  activo      Boolean  @default(true)
  orden       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("selecciones")
}

enum CategoriaReglamento {
  REGLAMENTO_JUEGO
  REGLAMENTO_COMPETENCIA
  ESTATUTO
  CIRCULAR
  OTRO
}

model Reglamento {
  id          String              @id @default(uuid())
  titulo      String
  descripcion String?
  archivoUrl  String
  categoria   CategoriaReglamento
  orden       Int                 @default(0)
  activo      Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@map("reglamentos")
}

model PaginaContenido {
  id        String   @id @default(uuid())
  clave     String   @unique
  titulo    String
  contenido String   @db.Text
  imagenUrl String?
  activo    Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@map("paginas_contenido")
}

model MensajeContacto {
  id        String   @id @default(uuid())
  nombre    String
  email     String
  telefono  String?
  asunto    String
  mensaje   String   @db.Text
  leido     Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("mensajes_contacto")
}

// ─── CPB BOT (Asistente IA) ─────────────────────────────

model ConversacionBot {
  id        String   @id @default(uuid())
  usuarioId String
  titulo    String   @default("Nueva conversación")
  activa    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mensajes MensajeBot[]

  @@map("conversaciones_bot")
}

model MensajeBot {
  id              String   @id @default(uuid())
  conversacionId  String
  role            String   // "user" | "assistant"
  contenido       String   @db.Text
  archivos        String?  @db.Text // JSON array of file URLs
  createdAt       DateTime @default(now())

  conversacion ConversacionBot @relation(fields: [conversacionId], references: [id], onDelete: Cascade)

  @@map("mensajes_bot")
}

// ─── PUSH NOTIFICATIONS ─────────────────────────────────

model PushToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String?
  userType  String?  // "oficial" | "ct" | "public"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("push_tokens")
}

// ─── PLANILLAS DE DESIGNACIÓN (GENIUS SPORTS) ───────────

model PlanillaDesignacion {
  id            String   @id @default(uuid())
  matchId       String   @unique  // Genius Sports matchId (string)

  // Snapshot del partido (actualizado al abrir)
  competicionId String
  categoria     String   // "LNB", "LNBF", etc.
  fecha         DateTime
  horaStr       String
  equipoLocal   String
  equipoVisit   String
  cancha        String?

  // Estado
  estado        String   @default("BORRADOR") // BORRADOR | CONFIRMADA

  // Árbitros
  ccId          String?
  ccNombre      String?
  a1Id          String?
  a1Nombre      String?
  a2Id          String?  // opcional
  a2Nombre      String?

  // Mesa
  apId          String?
  apNombre      String?
  cronId        String?
  cronNombre    String?
  lanzId        String?
  lanzNombre    String?
  estaId        String?  // opcional
  estaNombre    String?
  relaId        String?  // opcional
  relaNombre    String?

  obs           String?

  // Metadata
  creadoPorId       String
  creadoPorNombre   String
  confirmadoPorId   String?
  confirmadoPorNombre String?
  confirmadaEn      DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  logs          PlanillaDesignacionLog[]

  @@map("planillas_designacion")
}

model PlanillaDesignacionLog {
  id                   String   @id @default(uuid())
  planillaId           String
  planilla             PlanillaDesignacion @relation(fields: [planillaId], references: [id], onDelete: Cascade)

  accion               String   // "CREADA" | "MODIFICADA" | "CONFIRMADA" | "RECONFIRMADA"
  campo                String?  // "cc" | "a1" | "a2" | "ap" | "cron" | "lanz" | "esta" | "rela" | "obs" | "estado"
  valorAnteriorId      String?
  valorAnteriorNombre  String?
  valorNuevoId         String?
  valorNuevoNombre     String?

  cambiadoPorId        String
  cambiadoPorNombre    String
  cambiadoEn           DateTime @default(now())

  @@map("planillas_designacion_logs")
}

// ─── HONORARIOS PROPIOS (autogestión oficiales) ──────────
model HonorarioPropio {
  id            String    @id @default(uuid())
  usuarioId     String
  fecha         DateTime
  rama          String    // "Masculino" | "Femenino"
  categoria     String    // "PRIMERA_DIVISION" | "SEGUNDA_DIVISION" | "U21" | "U18" | "U16" | "U14" | "ESPECIAL"
  equipoA       String
  equipoB       String
  rol           String    // "ARBITRO" | "OFICIAL_MESA" | "ESTADISTICO" | "RELATOR"
  fase          String?   // "LNB_ETAPA1_ASU" etc. — solo para LNB_MASC
  faseNombre    String?   // "Etapa 1 — Asunción"
  montoSugerido Decimal?  @db.Decimal(12, 2)
  monto         Decimal   @db.Decimal(12, 2)
  // Valid: PENDIENTE | APROBADO | RECHAZADO | PAGADO
  estado        String    @default("PENDIENTE")
  pagadoEn      DateTime?
  notas         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  usuario       Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("honorarios_propios")
}

// ─── ARANCELES LNB v2 (LNB MASCULINO 2026) ───────────────
model ArancelLnb {
  id            String   @id @default(uuid())
  torneo        String   // "LNB_MASC"
  fase          String   // "LNB_ETAPA1_ASU", "LNB_TOP4_INT", etc.
  faseNombre    String   // "Etapa 1 — Asunción"
  rol           String   // "ARBITRO" | "ARBITRO_NAC" | "ARBITRO_INTL" | "OFICIAL_MESA" | "ESTADISTICO" | "RELATOR"
  montoUnitario Decimal  @db.Decimal(12, 2)
  cantPersonas  Int
  esManual      Boolean  @default(false) // true para ARBITRO_INTL (cotización manual)
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([torneo, fase, rol])
  @@map("aranceles_lnb")
}

// ─── TORNEO 3x3 ──────────────────────────────────────────
model Torneo3x3Equipo {
  id            String              @id @default(cuid())
  nombre        String
  ciudad        String?
  categoria     String              // "Femenino Open" | "Masculino Open"
  emailContacto String?
  telContacto   String?
  createdAt     DateTime            @default(now())
  jugadores     Torneo3x3Jugador[]

  @@map("torneo3x3_equipos")
}

model Torneo3x3Jugador {
  id        String   @id @default(cuid())
  equipoId  String
  nombre    String
  posicion  Int
  fechaNac  String?
  nroCi     String?
  celular   String?
  camiseta  String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  equipo    Torneo3x3Equipo @relation(fields: [equipoId], references: [id])

  @@map("torneo3x3_jugadores")
}

