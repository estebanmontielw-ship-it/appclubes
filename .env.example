# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Prisma)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.your-project.supabase.co:6543/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.your-project.supabase.co:5432/postgres

# App
NEXT_PUBLIC_BASE_URL=https://cpb.com.py

# Resend (emails)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@cpb.com.py

# Datos bancarios
NEXT_PUBLIC_BANCO_NOMBRE="Banco Continental"
NEXT_PUBLIC_BANCO_CUENTA=""
NEXT_PUBLIC_BANCO_TITULAR="Confederación Paraguaya de Basketball"
NEXT_PUBLIC_BANCO_RUC=""

# Sentry (monitoreo de errores)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Genius Sports — API key (requerida)
GENIUS_SPORTS_API_KEY=your-genius-sports-api-key

# Genius Sports — IDs de competencias (opcionales, se auto-detectan si no se definen)
GENIUS_LNB_COMPETITION_ID=48603
GENIUS_LNBF_COMPETITION_ID=
GENIUS_U22M_COMPETITION_ID=
GENIUS_U22F_COMPETITION_ID=

# Google Analytics 4 Data API (visualizaciones de noticias en admin)
GA4_PROPERTY_ID=530804213
GA4_CLIENT_EMAIL=cuenta-servicio@tu-proyecto.iam.gserviceaccount.com
GA4_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"

# Firebase (push notifications)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# AI (chatbot and content generation)
NVIDIA_API_KEY=
ANTHROPIC_API_KEY=

# Apple Wallet (pkpass generation)
APPLE_PASS_TYPE_ID=pass.com.example.cpb
APPLE_TEAM_ID=
APPLE_PASS_SIGNER_CERT_PEM=
APPLE_PASS_SIGNER_KEY_PEM=
APPLE_PASS_SIGNER_KEY_PASSWORD=
APPLE_PASS_WWDR_PEM=
